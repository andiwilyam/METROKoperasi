{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "onetool": {
      "type": "local",
      "command": ["C:/Users/ASUS NUC/.local/bin/onetool.exe", "--config", "C:/Users/ASUS NUC/.onetool/onetool.yaml"],
      "environment": {
        "DO_NOT_TRACK": "1"
      }
    },
    "one": {
      "type": "remote",
      "url": "https://mcp.withone.ai/mcp"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"],
      "environment": {
        "PW_MCP_HEADLESS": "1"
      }
    }
  }
}
