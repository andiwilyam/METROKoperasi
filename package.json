{
  "name": "metrocoop",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:all": "npm run build -w apps/web && npm run build:server",
    "start": "node dist/server.cjs",
    "db:migrate": "tsx server/migrate.ts",
    "db:seed": "tsx server/seed.ts",
    "lint": "tsc --noEmit -p packages/shared && tsc --noEmit -p apps/web",
    "typecheck": "tsc --noEmit -p packages/shared && tsc --noEmit -p apps/web",
    "test:e2e": "npm run test:e2e -w apps/web",
    "test:e2e:headed": "npm run test:e2e:headed -w apps/web",
    "test:e2e:ui": "npm run test:e2e:ui -w apps/web"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3",
    "tsx": "^4.21.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "typescript": "~5.8.2"
  }
}
