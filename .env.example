# ==================== METROCOOP ENVIRONMENT VARIABLES ====================
# Copy this file to .env and adjust values for your environment

# SERVER
PORT=3000
NODE_ENV=production

# JWT SECRET (WAJIB: ganti dengan string acak panjang untuk production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=metromitra-dev-secret-2026

# DATABASE (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metromitra
DB_USER=postgres
DB_PASS=postgres

# GEMINI AI (opsional — untuk fitur AI Audit Investasi)
GEMINI_API_KEY=""

# CORS (kosongkan jika frontend & backend satu domain)
# Jika frontend terpisah, isi dengan domain frontend, pisahkan dengan koma
CORS_ORIGIN=""

# APP URL (untuk link, callback, dll)
APP_URL="http://localhost:3000"
